# .env.example — העתק לקובץ ".env" ומלא את הערכים

# ── מסד נתונים ─────────────────────────────────────────────
DB_SERVER=localhost\SQLEXPRESS
DB_NAME=CleverCheck
DB_DRIVER=ODBC+Driver+17+for+SQL+Server

# ── מודל ────────────────────────────────────────────────────
MODEL_PATH=C:\Users\naamabc\PycharmProjects\FlaskProject\my_model

# ── הערכה ───────────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.65
LLM_REVIEW_MIN=0.40
LLM_REVIEW_MAX=0.85
NEGATION_WINDOW=5

# ── שרת ─────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=false

# ── SSL (פיתוח בלבד — false בפרודקשן!) ──────────────────────
DISABLE_SSL_VERIFY=true
